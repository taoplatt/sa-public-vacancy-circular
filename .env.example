# Copy this file to `.env` and paste your key. `.env` is git-ignored.
# run.py loads it automatically; enrichment + translation turn on when the key
# is set. With no key, the site still builds fully from the deterministic parse
# (English only; the other-language trees fall back to English).

# OpenRouter API key (https://openrouter.ai/keys). Used for both enrichment
# and translation via the OpenAI-compatible chat/completions endpoint.
OPENROUTER_API_KEY=sk-or-...

# Optional. Any OpenRouter model slug. Default: z-ai/glm-5.2.
# Examples: anthropic/claude-haiku-4.5, google/gemini-2.5-flash, z-ai/glm-5.2
# PSVC_MODEL=z-ai/glm-5.2

# Optional. Requests to keep in flight for the enrich/translate fan-out.
# PSVC_LLM_CONCURRENCY=8

# Optional. Reasoning effort for reasoning models (low|medium|high). Left unset,
# reasoning is DISABLED -- correct for these mechanical extract/translate tasks,
# and required for reasoning models like GLM 5.2 (otherwise chain-of-thought
# eats the output budget and the JSON answer truncates to empty).
# PSVC_REASONING_EFFORT=

# Optional. Custom domain for the deployed site. When set, the build writes a
# CNAME file to the site root so GitHub Pages serves it (e.g. jobs.example.com).
# PSVC_DOMAIN=

# Optional attribution shown on the OpenRouter dashboard.
# OPENROUTER_REFERER=https://github.com/taoplatt/sa-public-vacancy-circular
# OPENROUTER_TITLE=SA Public Vacancy Circular
